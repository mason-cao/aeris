# Database
DATABASE_URL=postgresql://aeris:aeris@localhost:5432/aeris

# Air Quality APIs
AIRNOW_API_KEY=
PURPLEAIR_API_KEY=

# Weather
OPENWEATHER_API_KEY=

# Traffic
TOMTOM_API_KEY=

# Energy
EIA_API_KEY=

# NASA / Satellite
NASA_EARTHDATA_TOKEN=

# Mapping (frontend uses this via API proxy)
MAPBOX_TOKEN=

# LLM (for cloud comparison only — local uses Ollama at localhost:11434)
OPENAI_API_KEY=
GOOGLE_API_KEY=

# App
AERIS_ENV=development
AERIS_LOG_LEVEL=INFO
AERIS_TARGET_LAT=
AERIS_TARGET_LON=
AERIS_TARGET_RADIUS_KM=50
